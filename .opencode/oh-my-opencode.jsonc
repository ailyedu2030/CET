{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "model": "volcengine/doubao-seed-2.0-code",
  "agents": {
    "sisyphus": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "hephaestus": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "oracle": {
      "model": "opencode/big-pickle",
      "temperature": 0.1
    },
    "librarian": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1
    },
    "explore": {
      "model": "volcengine/deepseek-v3.2",
      "temperature": 0.1
    },
    "multimodal-looker": {
      "model": "volcengine/kimi-k2.5",
      "temperature": 0.1
    },
    "metis": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.3
    },
    "momus": {
      "model": "volcengine/kimi-k2-thinking",
      "temperature": 0.1
    },
    "atlas": {
      "model": "opencode/big-pickle",
      "temperature": 0.1
    },
    "prometheus": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "sisyphus-junior": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1
    },
    "code-reviewer": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "security-reviewer": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "tdd-guide": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "e2e-runner": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "refactor-cleaner": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "python-reviewer": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "database-reviewer": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "build-error-resolver": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    },
    "doc-updater": {
      "model": "volcengine/kimi-k2-thinking",
      "temperature": 0.1
    },
    "go-reviewer": {
      "model": "volcengine/doubao-seed-2.0-code",
      "temperature": 0.1
    }
  },
  "categories": {
    "quick": {
      "model": "opencode/minimax-m2.5-free"
    },
    "visual-engineering": {
      "model": "volcengine/doubao-seed-2.0-code"
    },
    "ultrabrain": {
      "model": "volcengine/doubao-seed-2.0-code"
    },
    "deep": {
      "model": "volcengine/doubao-seed-2.0-code"
    },
    "artistry": {
      "model": "volcengine/kimi-k2.5"
    },
    "unspecified-low": {
      "model": "opencode/minimax-m2.5-free"
    },
    "unspecified-high": {
      "model": "volcengine/doubao-seed-2.0-code"
    },
    "writing": {
      "model": "volcengine/kimi-k2-thinking"
    }
  },
  "mcp": {
    "gitnexus": {
      "command": "npx",
      "args": ["-y", "gitnexus@latest", "mcp"]
    }
  },
  "features": {
    "ultrawork": {
      "enabled": true
    },
    "auto_context": {
      "inject_agents_md": true,
      "inject_readme": true
    },
    "background_agent": {
      "max_concurrent": 5
    },
    "learning": {
      "enabled": true
    }
  },
  "disabled_hooks": [],
  "disabled_skills": [],
  "disabled_commands": []
}
